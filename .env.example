# -----------------------------------------------------------------------------
# GigMarket - Environment Variables Example Template
# Copy this file to '.env' and fill in your actual credentials.
# WARNING: Never commit the actual '.env' file to your repository.
# -----------------------------------------------------------------------------

# Primary private key used as fallback for local signing/deployment (e.g., hardhat/viem)
PRIVATE_KEY="0x_your_local_private_key_hex"

# Circle Embedded Wallets (User-Controlled) configuration
CIRCLE_APP_ID="your_circle_app_id"

# Circle Developer Platform API Configuration
# Get your API key from https://console.circle.com/
CIRCLE_API_KEY="your_developer_platform_api_key"

# 32-byte entity secret in hex format, used for Developer-Controlled Wallets encryption
CIRCLE_ENTITY_SECRET="your_32_byte_hex_entity_secret"

# The Wallet ID and address of your Developer-Controlled Wallet
CIRCLE_WALLET_ID="your_developer_controlled_wallet_id"
CIRCLE_WALLET_ADDRESS="0x_your_developer_controlled_wallet_address"

# Secret used to verify signature on incoming GitHub/SCP webhook payloads
GITHUB_WEBHOOK_SECRET="your_webhook_signature_secret_for_x402"

# Circle Console Kit Key for App Kit Swap/Conversion operations
KIT_KEY="your_circle_console_kit_key"

# Circle Paymaster & Gas Station configurations for sponsored transaction gas
CIRCLE_PAYMASTER_ADDRESS="0x0000000071727E5C77c03C68673752c289654e53"
CIRCLE_PAYMASTER_POLICY_ID="your_paymaster_gas_station_policy_id"
